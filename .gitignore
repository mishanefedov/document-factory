# workspace contents are user-specific at ANY depth — ignore files, but keep
# directory structure + README.md files so the layout is self-documenting
# after clone.
**/workspace/**/*
!**/workspace/**/
!**/workspace/**/README.md
# …but the Next.js route that *serves* workspace files lives under
# app/workspace/[...path]/ and is code, not user data.
!packages/web/app/workspace/
!packages/web/app/workspace/**

# build artifacts
*.pdf
*.log
coverage/
.turbo/
.next/
.output/

# node / js
node_modules/
dist/
build/
.cache/
*.tsbuildinfo

# env / secrets — never commit any of these
.env
.env.*
!.env.example

# editors
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# agent/LSP metadata
.serena/
.claude/

# package manager caches
.pnpm-store/
